{
  "$schema": "http://json-schema.org/draft-04/schema",
  "type": "object",
  "description": "Status/terminal union returned by POST (may be terminal on a cache hit) and by GET on a polled job. Discriminated by `type`. See CLAUDE-ai-user-comments.md.",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "running",
        "success",
        "mentioned-in-passing",
        "gene-not-mentioned",
        "text-unavailable",
        "internal-error",
        "cancelled"
      ]
    },
    "job_id": { "type": "string" },
    "stage": {
      "type": "string",
      "description": "Present iff type=running.",
      "enum": [
        "queued",
        "fetching-article",
        "scanning-gene-mentions",
        "generating-summary",
        "persisting"
      ]
    },
    "ai_output": {
      "type": "object",
      "description": "Present iff type=success.",
      "properties": {
        "headline": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "comment_id": { "type": "integer" },
    "synonyms_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "description": "Source publication of the AI run. Present on every status that carries a job_id (running + the publishable terminals: success, mentioned-in-passing, gene-not-mentioned). Discriminated by `kind`; snake_case mirrors aiProvenance.source on GET /user-comments.",
      "oneOf": [
        {
          "properties": {
            "kind": { "type": "string", "enum": ["pubmed"] },
            "pubmed_id": { "type": "string" }
          },
          "required": ["kind", "pubmed_id"]
        },
        {
          "properties": {
            "kind": { "type": "string", "enum": ["upload"] },
            "pdf_content_sha256": { "type": "string" },
            "external_url": { "type": "string" },
            "external_title": { "type": "string" }
          },
          "required": ["kind", "pdf_content_sha256"]
        }
      ]
    },
    "reason": { "type": "string", "description": "Present iff type=text-unavailable." },
    "error": { "type": "string", "description": "Present iff type=internal-error." }
  },
  "required": ["type"]
}
